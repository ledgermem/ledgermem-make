{
  "name": "updateMemory",
  "label": "Update Memory",
  "description": "Updates the content or metadata of an existing memory.",
  "type": "action",
  "actionType": "update",
  "connection": "apikey",
  "parameters": [
    { "name": "id", "label": "Memory ID", "type": "text", "required": true },
    { "name": "content", "label": "Content", "type": "text" },
    { "name": "metadata", "label": "Metadata", "type": "array", "spec": {
      "type": "collection",
      "spec": [
        { "name": "key", "type": "text", "label": "Key" },
        { "name": "value", "type": "text", "label": "Value" }
      ]
    } }
  ],
  "communication": {
    "url": "/memories/{{encodeURL(parameters.id)}}",
    "method": "PATCH",
    "body": {
      "content": "{{parameters.content}}",
      "metadata": "{{toCollection(parameters.metadata, 'key', 'value')}}"
    },
    "response": { "output": "{{body}}" }
  },
  "interface": [
    { "name": "id", "label": "Memory ID", "type": "text" },
    { "name": "content", "label": "Content", "type": "text" }
  ]
}
